                "operationId": "getAbsensiById",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID absensi",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
